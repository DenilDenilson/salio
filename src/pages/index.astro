---
import AppLayout from "../layouts/AppLayout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

const matches = (await getCollection("matches")).sort(
  (left, right) =>
    new Date(right.data.kickoffAt).getTime() -
    new Date(left.data.kickoffAt).getTime(),
);

function phaseLabel(phase: "odds_captured" | "finalized"): string {
  return phase === "finalized" ? "Finalizado" : "Cuotas capturadas";
}

function phaseClass(phase: "odds_captured" | "finalized"): string {
  return phase === "finalized"
    ? "phase-finalized rounded-md border px-2 py-1 text-xs font-medium"
    : "phase-captured rounded-md border px-2 py-1 text-xs font-medium";
}

function formatDate(value: string): string {
  return new Intl.DateTimeFormat("es", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(new Date(value));
}
---

<AppLayout title="Stake Match Tracker">
  <main class="metal-shell">
    <section class="metal-header">
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
        <p
          class="text-sm font-semibold uppercase tracking-[0.16em] text-accent"
        >
          Snapshots post-partido versionados
        </p>
        <h1 class="mt-2 text-3xl font-semibold text-ink sm:text-4xl">
          Histórico de partidos
        </h1>
        <p class="mt-3 max-w-2xl text-neutral">
          Cuotas prepartido congeladas y resultados deportivos agregados desde
          archivos JSON validados en build.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
      {
        matches.length > 0 ? (
          <div class="grid gap-3">
            {matches.map((entry) => {
              const match = entry.data;
              const score = match.result?.score;
              return (
                <a
                  class="metal-card metal-card-hover grid gap-3 rounded-md p-4 md:grid-cols-[1fr_auto]"
                  href={`/partidos/${match.slug}`}
                >
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <h2 class="text-lg font-semibold text-ink">
                        {match.title}
                      </h2>
                      <span class={phaseClass(match.phase)}>
                        {phaseLabel(match.phase)}
                      </span>
                    </div>
                    <p class="mt-1 text-sm text-neutral">
                      {match.competitionName ?? "Competición sin nombre"} ·{" "}
                      {formatDate(match.kickoffAt)}
                    </p>
                    <p class="mt-2 text-sm text-neutral">
                      Cuotas capturadas {formatDate(match.odds.capturedAt)}
                    </p>
                  </div>
                  <div class="self-center border-line/70 pt-3 text-left md:border-l md:py-1 md:pl-5 md:text-right">
                    {score ? (
                      <>
                        <p class="text-sm font-medium text-neutral">
                          {match.result?.status}
                        </p>
                        <p class="mt-1 text-2xl font-bold tabular-nums text-ink drop-shadow-[0_0_12px_rgba(52,214,255,0.2)]">
                          {score.home} - {score.away}
                        </p>
                      </>
                    ) : (
                      <>
                        <p class="text-sm font-medium text-neutral">
                          Pendiente
                        </p>
                        <p class="mt-1 text-sm text-ink">Sin resultado</p>
                      </>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="metal-card rounded-md p-6 text-center">
            <h2 class="text-xl font-semibold text-ink">
              No hay snapshots publicados
            </h2>
            <p class="mt-2 text-neutral">
              Cuando captures cuotas o finalices un partido, aparecerá aquí.
            </p>
          </div>
        )
      }
    </section>
  </main>
</AppLayout>
