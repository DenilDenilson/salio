# Copia este archivo a .env.local y rellena tus secretos locales.
# cp .env.example .env.local

# Opcional para match:finalize / espn:validate reales.
# No requiere API key.
ESPN_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer
ESPN_LEAGUE_SLUG=fifa.world
ESPN_REQUEST_TIMEOUT_MS=30000

# Necesario para odds:capture real.
STAKE_ALLOWED_HOSTS=stake.pe
STAKE_API_ALLOWED_HOSTS=.websbkt.com
STAKE_API_TIMEOUT_MS=15000
STAKE_SAVE_RAW_RESPONSES=false

# Usa fixtures locales y provider demo si lo activas.
DEMO_MODE=false
